# Husky pre-commit hook — fast, opinionated.
# - Lint + typecheck only the workspaces that contain staged files (turbo handles the graph).
# - Skip on rebase / merge.

if git rev-parse -q --verify MERGE_HEAD >/dev/null; then
  exit 0
fi

echo "\u251c\u2500 Running typecheck \u2026"
pnpm -w typecheck || exit 1

echo "\u2514\u2500 Running lint \u2026"
pnpm -w lint || exit 1
