{
  "title": "YoCore — API Overview",
  "uid": "yocore-api-overview",
  "schemaVersion": 39,
  "version": 1,
  "tags": ["yocore", "api"],
  "timezone": "browser",
  "panels": [
    {
      "title": "HTTP request rate (req/s)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(yocore_http_request_duration_seconds_count[1m])) by (route, status)",
          "legendFormat": "{{route}} {{status}}"
        }
      ]
    },
    {
      "title": "HTTP latency p95 by route",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(yocore_http_request_duration_seconds_bucket[5m])) by (le, route))",
          "legendFormat": "p95 {{route}}"
        }
      ]
    },
    {
      "title": "Sign-in latency p50/p95/p99",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(yocore_signin_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(yocore_signin_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(yocore_signin_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "title": "Webhook deliveries by outcome",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(yocore_webhook_delivery_total[5m])) by (status)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "title": "Cron failures (rate / hour)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(yocore_cron_failure_total[1h])) by (job)",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "title": "Circuit breaker state (0=closed, 1=half, 2=open)",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "yocore_circuit_state",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "title": "In-flight HTTP requests",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "yocore_http_in_flight_requests"
        }
      ]
    },
    {
      "title": "Process memory (RSS)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "yocore_process_resident_memory_bytes"
        }
      ]
    }
  ]
}
