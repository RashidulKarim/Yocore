{
  "name": "yocore",
  "version": "1.0.0",
  "private": true,
  "description": "YoCore — Centralized SaaS backbone for Yo products (Auth + Billing + Workspaces + Bundles)",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration",
    "test:e2e": "playwright test --config=playwright.config.ts",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,yml,yaml}\""
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@playwright/test": "^1.47.2",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "turbo": "^2.1.3",
    "typescript": "^5.6.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,yml,yaml,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "pnpm": "^10.33.2"
  }
}
